      "fieldConfig": {
        "defaults": { "min": 0, "max": 20, "thresholds": { "mode": "absolute", "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 14 },
          { "color": "red", "value": 18 }
        ] } }
      }
    },
    {
      "title": "Capacity rejected (switch-out killer)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "targets": [
        { "expr": "listing_gate_capacity_rejected_total", "legendFormat": "503s", "refId": "A" }
      ]
    },
    {
      "title": "Avg analyze latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
