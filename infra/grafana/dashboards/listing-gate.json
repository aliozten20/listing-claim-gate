    {
      "title": "Inference slots (active / max)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "targets": [
        { "expr": "listing_gate_inference_slots_active", "legendFormat": "active", "refId": "A" },
        { "expr": "listing_gate_inference_slots_max", "legendFormat": "max", "refId": "B" }
