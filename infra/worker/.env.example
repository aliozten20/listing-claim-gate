# Example env for the local worker profile (copy to infra/worker/.env — gitignored).
#
# Create a Cloudflare named tunnel that points to http://mlc-proxy:8088
# then paste the token here:
#
#   TUNNEL_TOKEN=eyJ...
#
# Start:
#   docker compose --profile worker up -d --build
#
# On Render, set:
#   MLC_BASE_URL=https://<your-tunnel-hostname>
#
# FE never calls the tunnel; only Render /v1/mlc/* does.

TUNNEL_TOKEN=
