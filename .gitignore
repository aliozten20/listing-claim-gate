# Monorepo root ignores (per-package .gitignore files also apply)

# Env / secrets
**/.env
**/.env.local
**/.env.*.local
infra/worker/.env

# Local clones / forks (not part of delivery tree)
.refs/

# Node / Next.js
**/node_modules/
**/.next/
**/out/

# Go build artifacts
backend/app
backend/server
backend/llm-monitoring-api

# Misc
.DS_Store
*.log
