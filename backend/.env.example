# Copy to .env for local development. Do NOT commit real secrets.
APP_ENV=development
PORT=8080

# Local Docker Compose Postgres:
DATABASE_URL=postgres://listing:listing@localhost:5432/listing_claim_gate?sslmode=disable
# Production (Supabase) example:
# DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# This value is fine for local development ONLY.
# Generate production secret: openssl rand -base64 48
JWT_SECRET=dev-insecure-secret-change-me-but-32b-min!!
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h

CORS_ORIGINS=http://localhost:3000
TRUST_PROXY=false
REQUEST_TIMEOUT=15s
BCRYPT_COST=12

APP_NAME=Listing & Claim Gate
APP_VERSION=0.1.0

# Optional MLC / OpenAI-compatible inference (empty = rules engine only)
MLC_BASE_URL=
MAX_CONCURRENT_INFERENCES=20
